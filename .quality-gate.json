{
    "commands": {
        "build": "make build",
        "coverage": "make test-coverage",
        "lint": "make lint",
        "security": "make security-gate-scan",
        "tests": "make test",
        "types": "make type-check"
    },
    "description": "Quality gate configuration for mixed project",
    "thresholds": {
        "build": {
            "operator": "=",
            "type": "exit_code",
            "value": 0
        },
        "coverage": {
            "operator": "\u2265",
            "type": "percentage"
        },
        "lint": {
            "operator": "=",
            "type": "count",
            "value": 0
        },
        "security": {
            "operator": "=",
            "type": "count",
            "value": 0
        },
        "tests": {
            "operator": "\u2265",
            "type": "count"
        },
        "types": {
            "operator": "\u2264",
            "type": "count"
        }
    }
}
