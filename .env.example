# ─── Observability ────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=development
RELEASE=docker-overview-api@1.0.0

# ─── Auth ──────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── LDAP (optionnel) ──────────────────────────────────────
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# ─── Chemins ───────────────────────────────────────────────
# Répertoire contenant les sous-dossiers de projets docker-compose
PROJECTS_PATH=/opt/projects

# ─── Demo mode ─────────────────────────────────────────────
# When true, the API serves fixture data instead of reading the real Docker
# socket / projects directory, and accepts the built-in demo/demo credentials.
# An amber "DEMO" banner is shown in the UI. OFF by default — never enable in prod.
DEMO_MODE=false

# ─── Ports ─────────────────────────────────────────────────
FRONTEND_PORT=3000

# ─── URL de l'API (vue depuis le navigateur, bakée au build) ─
# Laisser vide si un proxy reverse (nginx, Caddy...) proxifie /api
# Sinon : http://<hote>:<port_api>  ex: http://localhost:8000
VITE_API_URL=http://localhost:8000
