{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (FastAPI/uvicorn)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000,
      "cwd": "api"
    },
    {
      "name": "Frontend (Vite/React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "code"
    }
  ]
}
